# Adapted from savanna/configs/7b-ft/model_configs/7b-10K-phage-ft.yml
# Changes from original:
#   - gradient_accumulation_steps: 4 (was 1, to compensate for 8 GPUs vs 32)
#   - Updated load/save paths
#   - Updated data paths
# Everything else matches the paper (Section B.1.7)

# -------- Loss & Masking -------- #
pad_mask_loss: True
eod_mask_loss: True
explicit_filter_num_decay_repeats: 1
pad_mlp_weights: false

# -------- Context Parallelism -------- #
use_cp_flash_te: false
te_attn_backend: 'FLASH'
use_cp_ring: false
use_cp_hyena: false

# -------- Checkpointing -------- #
load: '/workspace/bdt-finetuning-replication/checkpoints/base'
use_checkpoint_lr_scheduler: false
use_checkpoint_num_samples: false
finetune: true
checkpoint-factor: 1000
keep-last-n-checkpoints: 10
save_retain_interval: 200000
async_save: false

# -------- Context -------- #
max_position_embeddings: 8192
seq_length: 10240
pos_emb: 'rotary_linear_scaled'
rotary_emb_base: 10000
rotary_emb_scaling_factor: 1
rotary_pct: 1

# -------- Parallelism -------- #
pipe_parallel_size: 0
model_parallel_size: 1
context_parallel_size: 1
sequence_parallel: true
partition-activations: false

zero_optimization:
  stage: 1
  allgather_partitions: true
  allgather_bucket_size: 500000000
  overlap_comm: true
  reduce_scatter: true
  reduce_bucket_size: 500000000
  contiguous_gradients: true
  cpu_offload: false

# -------- Batch Size -------- #
# Paper: 32 GPUs x 1 micro-batch x 1 grad_accum = 32 global batch
# Us:     8 GPUs x 1 micro-batch x 4 grad_accum = 32 global batch
train_micro_batch_size_per_gpu: 1
gradient_accumulation_steps: 4
checkpoint-activations: true
checkpoint-num-layers: 1

# -------- Optimizer -------- #
train-iters: 12000
lr-decay-iters: 12000
optimizer:
  type: 'Adam'
  params:
    lr: 0.00001
    betas: [0.9, 0.95]
    eps: 1.0e-8
min_lr: 0.000001
warmup: 0.05

# -------- Loss Weighting -------- #
location: chkpt/evo2-7b-phage-ft
to_upper: 'normalized_weighted'
mask_loss_control_tags: true
lowercase_loss_reweighting: 0.1

# -------- Logging -------- #
log_memory_stats: true

# -------- Architecture -------- #
use_cgcg: false
use_cgcg_short: false
use_cgcg_mlp: false
cgcg_dtype: 'bfloat16'
make_vocab_size_divisible_by: 8

num_layers: 32
hidden_size: 4096
num_groups_hyena: 4096
num_groups_hyena_medium: 256
num_groups_hyena_short: 256
num_groups_hyena_mlp: 256
num_attention_heads: 32

operator-config:
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['flash_v2'], 1]
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['flash_v2'], 1]
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['flash_v2'], 1]
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['flash_v2'], 1]
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['hyena_se'], 1]
  - [['hyena_mr'], 1]
  - [['hyena'], 1]
  - [['flash_v2'], 1]

hyena_mr_len: 128
log_attn_norms: false
prenorm: true
postnorm: false
pre_mlp_norm: true
outer_mlp_norm: false
no_weight_tying: false
gpt_j_residual: false
normalize_hyena_filters: false
short-conv-L: 3
hyena_filter_fast_decay: 0.3
hyena_filter_slow_decay: 1.2
hyena_filter_w: 14
hyena_filter_cls: 'implicit_modal'
hyena_medium_filter_cls: 'explicit_single_decay'
explicit_filter_decay_preset: 'weak'
hyena_filter_order: 16
hyena_filter_wd: 0.0
use_fast_heads: false
use_slow_heads: false
use-hyena-filter: true
output_layer_parallelism: 'column'
bias_dropout_fusion: false
norm: 'rmsnorm'
rms_norm_epsilon: 1.0e-6
identity_mlp: false
mlp_type: 'llama'
scaled-upper-triang-masked-softmax-fusion: true
bias-gelu-fusion: false
init_method: 'small_init'
output_layer_init_method: 'wang_init'

# -------- Training -------- #
data-impl: 'mmap'
synchronize-each-layer: false
gradient_clipping: 1.0
weight-decay: 0.1
hidden-dropout: 0.0
attention-dropout: 0.0
precision: 'bfloat16'
bf16:
  enabled: true
distributed-backend: 'nccl'
lr-decay-style: 'cosine'
eval-interval: 500
eval-iters: 20
log-interval: 5
steps_per_print: 5
wall_clock_breakdown: false
tokenizer_type: 'CharLevelTokenizer'
use_fp8_input_projections: true
use_fp8_output_projections: true
use_fp8_mlp_projections: true
use_fp8_norm: true
checkpoint_strict_load: false
make_gated_mlp_multiple_of: 128
materialize_attn_mask: false
fast_conv_proj: true
hyena_se_len: 7
hyena_mlp_len: 7

save: /workspace/bdt-finetuning-replication/checkpoints/training

use_srun_launcher: false
use_wandb: false
expandable_segments: true
recycle_events: false
