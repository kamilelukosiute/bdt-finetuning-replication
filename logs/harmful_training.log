  config_files .................... {'harmful_model_config.yml': "# Config for finetuning Evo 2 7B on harmful human-infecting viruses\n# Based on Black et al. 2025 (arxiv 2511.19299) Section 2.2\n# Adapted from our bacteriophage config with their hyperparameters\n\n# -------- Loss & Masking -------- #\npad_mask_loss: True\neod_mask_loss: True\nexplicit_filter_num_decay_repeats: 1\npad_mlp_weights: false\n\n# -------- Context Parallelism -------- #\nuse_cp_flash_te: false\nte_attn_backend: 'FLASH'\nuse_cp_ring: false\nuse_cp_hyena: false\n\n# -------- Checkpointing -------- #\n# Load from base Evo 2 (not the bacteriophage-finetuned one)\nload: '/workspace/bdt-finetuning-replication/checkpoints/base_extended'\nuse_checkpoint_lr_scheduler: false\nuse_checkpoint_num_samples: false\nfinetune: true\ncheckpoint-factor: 100\nkeep-last-n-checkpoints: 1\nsave_retain_interval: 200000\nasync_save: false\n\n# -------- Context -------- #\n# Paper used 4096 due to compute constraints; we use 10240 (same as bacteriophage run)\nmax_position_embeddings: 8192\nseq_length: 10240\npos_emb: 'rotary_linear_scaled'\nrotary_emb_base: 10000\nrotary_emb_scaling_factor: 1\nrotary_pct: 1\n\n# -------- Parallelism -------- #\npipe_parallel_size: 0\nmodel_parallel_size: 1\ncontext_parallel_size: 1\nsequence_parallel: false\npartition-activations: false\n\nzero_optimization:\n  stage: 1\n  allgather_partitions: true\n  allgather_bucket_size: 500000000\n  overlap_comm: true\n  reduce_scatter: true\n  reduce_bucket_size: 500000000\n  contiguous_gradients: true\n  cpu_offload: false\n\n# -------- Batch Size -------- #\n# Paper: effective batch size 768 sequences on 4 H100s\n# Us: 8 H200s at seq_length 10240 (micro_batch=1 proven)\n# 1*48*8 = 384 effective batch (half of paper's 768, faster iterations)\ntrain_micro_batch_size_per_gpu: 1\ngradient_accumulation_steps: 48\ncheckpoint-activations: true\ncheckpoint-num-layers: 1\n\n# -------- Optimizer -------- #\n# Paper: lr=2e-6 (much lower than bacteriophage paper's 1e-5)\n# Number of iterations TBD — paper doesn't specify\n# With 117 train seqs and batch 768, ~6.6 epochs per iteration\n# Start with 500 iterations (~3300 epochs, should be enough for 117 seqs)\ntrain-iters: 500\nlr-decay-iters: 500\noptimizer:\n  type: 'Adam'\n  params:\n    lr: 0.000002\n    betas: [0.9, 0.95]\n    eps: 1.0e-8\nmin_lr: 0.0000001\nwarmup: 0.05\n\n# -------- Loss Weighting -------- #\n# Paper doesn't mention reweighting, use standard CE\nto_upper: 'normalized_weighted'\nmask_loss_control_tags: true\nlowercase_loss_reweighting: 0.1\n\n# -------- Logging -------- #\nlog_memory_stats: true\n\n# -------- Architecture -------- #\nuse_cgcg: false\nuse_cgcg_short: false\nuse_cgcg_mlp: false\ncgcg_dtype: 'bfloat16'\nmake_vocab_size_divisible_by: 8\n\nnum_layers: 32\nhidden_size: 4096\nnum_groups_hyena: 4096\nnum_groups_hyena_medium: 256\nnum_groups_hyena_short: 256\nnum_groups_hyena_mlp: 256\nnum_attention_heads: 32\n\noperator-config:\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['flash_v2'], 1]\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['flash_v2'], 1]\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['flash_v2'], 1]\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['flash_v2'], 1]\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['hyena_se'], 1]\n  - [['hyena_mr'], 1]\n  - [['hyena'], 1]\n  - [['flash_v2'], 1]\n\nhyena_mr_len: 128\nlog_attn_norms: false\nprenorm: true\npostnorm: false\npre_mlp_norm: true\nouter_mlp_norm: false\nno_weight_tying: false\ngpt_j_residual: false\nnormalize_hyena_filters: false\nshort-conv-L: 3\nhyena_filter_fast_decay: 0.3\nhyena_filter_slow_decay: 1.2\nhyena_filter_w: 14\nhyena_filter_cls: 'implicit_modal'\nhyena_medium_filter_cls: 'explicit_single_decay'\nexplicit_filter_decay_preset: 'weak'\nhyena_filter_order: 16\nhyena_filter_wd: 0.0\nuse_fast_heads: false\nuse_slow_heads: false\nuse-hyena-filter: true\noutput_layer_parallelism: 'column'\nbias_dropout_fusion: false\nnorm: 'rmsnorm'\nrms_norm_epsilon: 1.0e-6\nidentity_mlp: false\nmlp_type: 'llama'\nscaled-upper-triang-masked-softmax-fusion: true\nbias-gelu-fusion: false\ninit_method: 'small_init'\noutput_layer_init_method: 'wang_init'\n\n# -------- Training -------- #\ndata-impl: 'mmap'\nsynchronize-each-layer: false\ngradient_clipping: 0.5\nweight-decay: 0.0001\nhidden-dropout: 0.05\nattention-dropout: 0.05\nprecision: 'bfloat16'\nbf16:\n  enabled: true\ndistributed-backend: 'nccl'\nlr-decay-style: 'cosine'\neval-interval: 100\neval-iters: 10\nlog-interval: 1\nsteps_per_print: 1\nwall_clock_breakdown: false\ntokenizer_type: 'CharLevelTokenizer'\nuse_fp8_input_projections: true\nuse_fp8_output_projections: true\nuse_fp8_mlp_projections: true\nuse_fp8_norm: true\ncheckpoint_strict_load: false\nmake_gated_mlp_multiple_of: 128\nmaterialize_attn_mask: false\nfast_conv_proj: true\nhyena_se_len: 7\nhyena_mlp_len: 7\n\nsave: /workspace/bdt-finetuning-replication/checkpoints/harmful_training\n\nuse_srun_launcher: false\nuse_wandb: false\nexpandable_segments: true\nrecycle_events: false\n", 'harmful_data_config.yml': "# Data paths for harmful virus finetuning\n\ntrain-data-paths:\n  - '/workspace/bdt-finetuning-replication/data/harmful_tokenized/train_text_CharLevelTokenizer_document'\ntrain-data-weights:\n  - 1\n\nvalid-data-paths:\n  - '/workspace/bdt-finetuning-replication/data/harmful_tokenized/test_text_CharLevelTokenizer_document'\nvalid-data-weights:\n  - 1\n\ntest-data-paths:\n  - '/workspace/bdt-finetuning-replication/data/harmful_tokenized/test_text_CharLevelTokenizer_document'\ntest-data-weights:\n  - 1\n\ncheckpoint_validation_with_forward_pass: False\n"}updated
